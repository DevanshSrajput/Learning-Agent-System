# ===============================
# Learning Agent System - Example Environment
# Copy this file to `.env` and fill values as needed.
# ===============================

# Core runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
THRESHOLD=0.7

# Optional Hugging Face token (helps avoid anonymous rate limits)
HF_TOKEN=

# LangSmith tracing (optional)
LANGSMITH_TRACING_ENABLED=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=Learning-Agent-System
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# For EU-hosted LangSmith accounts, use:
# LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
